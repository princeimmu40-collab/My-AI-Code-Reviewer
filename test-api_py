import os
import google.generativeai as genai

# మీ API కీని ఇక్కడ పేస్ట్ చేయండి (టెస్టింగ్ కోసం మాత్రమే)
# గమనిక: ఇది కేవలం టెస్టింగ్ కోసం, GitHub Actions లో వాడేటప్పుడు secrets వాడండి
api_key = "YOUR_AIza_KEY_HERE" 

try:
    genai.configure(api_key=api_key)
    model = genai.GenerativeModel('gemini-1.5-flash')
    
    response = model.generate_content("Hello, can you verify that the API connection is working?")
    print("API కనెక్షన్ విజయవంతమైంది!")
    print("AI సమాధానం:", response.text)

except Exception as e:
    print("API కనెక్షన్ విఫలమైంది. ఎర్రర్ వివరాలు:")
    print(e)
